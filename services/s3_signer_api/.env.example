AWS_S3_BUCKET=bgrub-bucket
AWS_S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_S3_PREFIX=task_attachments
FIREBASE_SERVICE_ACCOUNT_PATH=C:/path/to/firebase-service-account.json
# Optional: add extra non-local origins when needed.
S3_API_ALLOWED_ORIGINS=
# Optional: override the default localhost/127.0.0.1 any-port pattern.
S3_API_ALLOWED_ORIGIN_REGEX=^https?://(localhost|127\.0\.0\.1)(:\d+)?$