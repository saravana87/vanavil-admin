rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isCurrentAdmin() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isSuperAdmin() {
      return isCurrentAdmin() &&
        get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.role in [
          'super_admin',
          'super-admin',
          'superadmin',
        ];
    }

    function isChildUser() {
      return isSignedIn() &&
        request.auth.token.role == 'child' &&
        request.auth.token.childId is string &&
        request.auth.token.childId.size() > 0;
    }

    function currentChildId() {
      return request.auth.token.childId;
    }

    function isOwnAdminDoc(adminId) {
      return isCurrentAdmin() && request.auth.uid == adminId;
    }

    function isOwnAdminPath(adminId) {
      return isSignedIn() && request.auth.uid == adminId;
    }

    function isOwnChildDoc(childId) {
      return isChildUser() && currentChildId() == childId;
    }

    function childBelongsToAdmin(data) {
      return data.adminId == request.auth.uid;
    }

    function childBelongsToCurrentAdminById(childId) {
      return isCurrentAdmin() &&
        exists(/databases/$(database)/documents/children/$(childId)) &&
        (
          isSuperAdmin() ||
          get(/databases/$(database)/documents/children/$(childId)).data.adminId == request.auth.uid
        );
    }

    function canAccessChild(data) {
      return isCurrentAdmin() && (isSuperAdmin() || childBelongsToAdmin(data));
    }

    function canAccessTask(data) {
      return isCurrentAdmin() && (isSuperAdmin() || taskBelongsToAdmin(data));
    }

    function canAccessAssignment(data) {
      return isCurrentAdmin() && (isSuperAdmin() || assignmentBelongsToAdmin(data));
    }

    function taskBelongsToAdmin(data) {
      return data.createdBy == request.auth.uid;
    }

    function assignmentBelongsToAdmin(data) {
      return data.assignedBy == request.auth.uid;
    }

    function assignmentBelongsToCurrentChild(data) {
      return isOwnChildDoc(data.childId);
    }

    function assignmentBelongsToCurrentChildById(assignmentId) {
      return isChildUser() &&
        exists(/databases/$(database)/documents/assignments/$(assignmentId)) &&
        get(/databases/$(database)/documents/assignments/$(assignmentId)).data.childId == currentChildId();
    }

    function childCanSubmitAssignment() {
      return assignmentBelongsToCurrentChild(resource.data) &&
        resource.data.status in ['assigned', 'rejected'] &&
        request.resource.data.status == 'submitted' &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'status',
          'submittedAt',
          'updatedAt',
        ]);
    }

    function childCanMarkNotificationRead() {
      return isOwnChildDoc(resource.data.childId) &&
        request.resource.data.childId == resource.data.childId &&
        request.resource.data.isRead == true &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'isRead',
        ]);
    }

    match /admins/{adminId} {
      allow create: if isSignedIn() && request.auth.uid == adminId;
      allow read: if isOwnAdminPath(adminId) || isSuperAdmin();
      allow update: if isOwnAdminDoc(adminId) || isSuperAdmin();
      allow delete: if false;
    }

    match /children/{childId} {
      allow read: if canAccessChild(resource.data);
      allow read: if isOwnChildDoc(childId);
      allow create: if canAccessChild(request.resource.data);
      allow update: if canAccessChild(resource.data);
      allow delete: if false;
    }

    match /tasks/{taskId} {
      allow read: if canAccessTask(resource.data);
      allow read: if isChildUser() && resource.data.templateStatus == 'active';
      allow create: if canAccessTask(request.resource.data);
      allow update: if canAccessTask(resource.data);
      allow delete: if false;
    }

    match /assignments/{assignmentId} {
      allow read: if canAccessAssignment(resource.data);
      allow read: if assignmentBelongsToCurrentChild(resource.data);
      allow create: if canAccessAssignment(request.resource.data);
      allow update: if canAccessAssignment(resource.data);
      allow update: if childCanSubmitAssignment();
      allow delete: if false;
    }

    match /announcements/{announcementId} {
      allow read, create, update: if isCurrentAdmin();
      allow read: if isChildUser();
      allow delete: if false;
    }

    match /badges/{badgeId} {
      allow read, create, update: if isCurrentAdmin();
      allow read: if isChildUser();
      allow delete: if false;
    }

    match /child_badges/{childBadgeId} {
      allow read: if isCurrentAdmin() && childBelongsToCurrentAdminById(resource.data.childId);
      allow create: if isCurrentAdmin() && childBelongsToCurrentAdminById(request.resource.data.childId);
      allow update: if isCurrentAdmin() && childBelongsToCurrentAdminById(resource.data.childId);
      allow read: if isOwnChildDoc(resource.data.childId);
      allow delete: if false;
    }

    match /reviews/{reviewId} {
      allow read: if isCurrentAdmin() && childBelongsToCurrentAdminById(resource.data.childId);
      allow create: if isCurrentAdmin() && childBelongsToCurrentAdminById(request.resource.data.childId);
      allow update: if isCurrentAdmin() && childBelongsToCurrentAdminById(resource.data.childId);
      allow read: if assignmentBelongsToCurrentChildById(resource.data.assignmentId);
      allow delete: if false;
    }

    match /points_ledger/{entryId} {
      allow read: if isCurrentAdmin() && childBelongsToCurrentAdminById(resource.data.childId);
      allow create: if isCurrentAdmin() && childBelongsToCurrentAdminById(request.resource.data.childId);
      allow update: if isCurrentAdmin() && childBelongsToCurrentAdminById(resource.data.childId);
      allow read: if isOwnChildDoc(resource.data.childId);
      allow delete: if false;
    }

    match /submissions/{submissionId} {
      allow read: if isCurrentAdmin() && childBelongsToCurrentAdminById(resource.data.childId);
      allow read: if isOwnChildDoc(resource.data.childId);
      allow create: if isChildUser() &&
        request.resource.data.childId == currentChildId() &&
        assignmentBelongsToCurrentChildById(request.resource.data.assignmentId);
      allow update, delete: if false;
    }

    match /notifications/{notificationId} {
      allow read: if isCurrentAdmin() && childBelongsToCurrentAdminById(resource.data.childId);
      allow create: if isCurrentAdmin() && childBelongsToCurrentAdminById(request.resource.data.childId);
      allow update: if isCurrentAdmin() && childBelongsToCurrentAdminById(resource.data.childId);
      allow read: if isOwnChildDoc(resource.data.childId);
      allow update: if childCanMarkNotificationRead();
      allow delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}