# Repository publishing policy

# Child app is now tracked in Git. Keep only local signing secrets out.
apps/child_app/android/key.properties
apps/child_app/android/**/*.keystore
apps/child_app/android/**/*.jks
functions/

# Secrets and local credentials
.env
*.env
*.local
*.secret
*.pem
*.key
*.p12
*.pfx
aws_cred
aws_cred/
private/
private/**
services/s3_signer_api/*firebase-adminsdk*.json
functions/*firebase-adminsdk*.json

# Python virtual environments and caches
.venv/
venv/
**/.venv/
**/__pycache__/
**/*.pyc

# Flutter, Dart, and generated build output
.dart_tool/
**/.dart_tool/
.flutter-plugins-dependencies
.pub/
.pub-cache/
build/
**/build/
coverage/

# Node dependencies
node_modules/
**/node_modules/

# IDE and OS files
.idea/
.vscode/
.claude/
*.iml
.metadata
.DS_Store
Thumbs.db
*.log

# Docker local overrides
docker-compose.override.yml